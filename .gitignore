rust/

# Disk-staged user binaries — produced by tools/build-disk.sh from the
# real source crates (console/, umode/, hello-std/). Text fixtures
# under rootfs/ remain tracked.
rootfs/bin/console
rootfs/bin/smoke
rootfs/bin/hello-std

runs/