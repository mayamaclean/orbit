#!/usr/bin/env bash
#
# Orbit end-to-end smoke test. Builds the three privilege layers in the
# order their include_bytes paths require, boots QEMU, and drives the
# umode TCP loopback demo via an nc(1) listener on the host.
#
# QEMU's user-mode NAT maps the guest's default gateway (192.168.76.2)
# to the host loopback, so an nc listener on host :65535 receives the
# guest's connection. The feeder sends "hi!" then "exit" after the guest
# has connected; "exit" is what umode's recv loop looks for to drop into
# the close_handle path.
#
# Expected path:
#   hello world → sleep 5s → nc_create → tcp connect
#     → send "Hello World!" → recv "hi!" → recv "exit" → close_handle
#
# Exit 0 on success; non-zero on first missing marker. Override
# QEMU_TIMEOUT in the environment to adjust the overall wall-clock cap.

set -euo pipefail

ROOT=$(cd "$(dirname "$0")" && pwd)
QEMU_LOG=/tmp/orbit-smoke-qemu.log
NC_LOG=/tmp/orbit-smoke-nc.log
: "${QEMU_TIMEOUT:=25}"

die()  { echo "FAIL: $*" >&2; exit 1; }
note() { printf ">> %s\n" "$*"; }

# --- mode selection ---
# Default: the umode TCP/tarfs/syscall smoke (what the rest of this
# script implements). `--perms-roles`: build + ship `smoke-perms-roles`
# to a running orbit-loader, assert its PASS marker. The two modes
# share build-layer code via `build_kernel_and_disk` but otherwise
# branch in `main`.
MODE=default
while (( $# )); do
  case "$1" in
    --perms-roles)
      MODE=perms-roles
      shift
      ;;
    -h|--help)
      cat <<USAGE
Usage: $0 [MODE]

Modes:
  (no args)        umode TCP/tarfs/syscall smoke (default)
  --perms-roles    ship smoke-perms-roles to orbit-loader and assert PASS
USAGE
      exit 0
      ;;
    *)
      die "unknown option: $1 (try --help)"
      ;;
  esac
done

# Forward declarations so `main`-style branching reads top-down.
run_perms_roles_smoke() {
  # Build the kernel with the *default* feature set so init = /bin/console
  # (the loader still listens on :7777 alongside its init spawn, so
  # we can ship perms-roles to it via send-payload.py).
  note "building orbit-loader (release)"
  ( cd "$ROOT/orbit-loader" && cargo build --release --bin orbit-loader >/dev/null )
  note "building kmain (release, default features → init=/bin/console)"
  ( cd "$ROOT/kmain" && ./build.sh >/tmp/orbit-pr-kmain-build.log 2>&1 ) \
    || die "kmain build failed (see /tmp/orbit-pr-kmain-build.log)"
  note "building bl (release)"
  ( cd "$ROOT/bl" && cargo build --release --bin launch >/dev/null )
  BL_BIN="$ROOT/bl/target/riscv64gc-unknown-none-elf/release/launch"
  [ -x "$BL_BIN" ] || die "bl binary missing at $BL_BIN"

  # smoke-stub-child must build before smoke-perms-roles (it's
  # include_bytes!'d as the v2-spawn ELF blob).
  note "building smoke-stub-child (release) — embedded as v2 spawn payload"
  ( cd "$ROOT/smoke-stub-child" && cargo build --release >/dev/null )
  note "building smoke-perms-roles (release)"
  ( cd "$ROOT/smoke-perms-roles" && cargo build --release >/dev/null )
  PR_ELF="$ROOT/smoke-perms-roles/target/riscv64gc-unknown-none-elf/release/smoke-perms-roles"
  [ -s "$PR_ELF" ] || die "smoke-perms-roles binary missing at $PR_ELF"

  note "building disk.img (loader needs tarfs to read /bin/console)"
  "$ROOT/tools/build-disk.sh" >/dev/null
  [ -s "$ROOT/disk.img" ] || die "disk.img missing at $ROOT/disk.img"

  # Pre-flight: the loader's TCP listener uses guest port 7777 and
  # we map it to host 7777 via -hostfwd. If something else owns the
  # host port, send-payload would fail silently.
  if ss -ltn 2>/dev/null | grep -q ':7777 '; then
    die "host port 7777 already in use — kill the existing listener (ss -ltnp | grep :7777)"
  fi

  note "booting qemu in background (timeout ${QEMU_TIMEOUT}s)"
  : >"$QEMU_LOG"
  timeout "$QEMU_TIMEOUT" qemu-system-riscv64 \
    -d guest_errors -smp 4 -m 2G \
    -machine virt,aclint=on -cpu max,sstc=true \
    -nographic -bios none -serial mon:stdio \
    -netdev user,id=orbit0,net=192.168.76.0/24,dhcpstart=192.168.76.9,hostfwd=tcp::7777-:7777 \
    -device e1000,netdev=orbit0 \
    -global virtio-mmio.force-legacy=off \
    -drive file="$ROOT/disk.img",format=raw,if=none,id=hd0,readonly=on,file.locking=off \
    -device virtio-blk-device,drive=hd0 \
    -kernel "$BL_BIN" \
    </dev/null >>"$QEMU_LOG" 2>&1 &
  QEMU_PID=$!
  trap 'kill "$QEMU_PID" 2>/dev/null || true' EXIT

  # Wait for the loader to advertise its TCP listener. Cap at half the
  # overall timeout so a stuck boot fails fast rather than after the
  # full QEMU window.
  note "waiting for orbit-loader to start listening on :7777"
  WAIT_DEADLINE=$(( $(date +%s) + QEMU_TIMEOUT / 2 ))
  while ! grep -q 'orbit-loader: listening on :7777' "$QEMU_LOG" 2>/dev/null; do
    if (( $(date +%s) >= WAIT_DEADLINE )); then
      kill "$QEMU_PID" 2>/dev/null || true
      tail -n 50 "$QEMU_LOG" >&2 || true
      die "orbit-loader never came up (no 'listening on :7777' in $QEMU_LOG)"
    fi
    if ! kill -0 "$QEMU_PID" 2>/dev/null; then
      tail -n 50 "$QEMU_LOG" >&2 || true
      die "QEMU exited before orbit-loader was ready"
    fi
    sleep 0.5
  done

  note "shipping smoke-perms-roles via send-payload.py"
  python3 "$ROOT/orbit-loader/tools/send_payload.py" "$PR_ELF" \
    --name smoke-perms-roles >/tmp/orbit-pr-send.log 2>&1 \
    || die "send-payload failed (see /tmp/orbit-pr-send.log)"

  note "waiting for PASS / FAIL marker"
  while ! grep -qE '(PASS|FAIL) smoke-perms-roles' "$QEMU_LOG" 2>/dev/null; do
    if ! kill -0 "$QEMU_PID" 2>/dev/null; then
      break  # QEMU exited, fall through to the marker check
    fi
    sleep 0.3
  done

  # Stop QEMU cleanly so the log is final.
  kill "$QEMU_PID" 2>/dev/null || true
  wait "$QEMU_PID" 2>/dev/null || true

  if grep -q '^.*PASS smoke-perms-roles' "$QEMU_LOG"; then
    note "smoke-perms-roles PASS"
    grep 'smoke-perms-roles' "$QEMU_LOG" | tail -10
    exit 0
  fi
  if grep -q '^.*FAIL smoke-perms-roles' "$QEMU_LOG"; then
    grep 'smoke-perms-roles' "$QEMU_LOG" | tail -20 >&2
    die "smoke-perms-roles FAILed (see $QEMU_LOG)"
  fi
  tail -n 100 "$QEMU_LOG" >&2 || true
  die "smoke-perms-roles never reported PASS or FAIL (see $QEMU_LOG)"
}

if [[ $MODE == perms-roles ]]; then
  run_perms_roles_smoke
fi

# --- build layers ---
# kmain always embeds orbit-loader; the `smoke` cargo feature on kmain
# now selects the init *path* (/bin/smoke instead of /bin/console)
# rather than the embedded ELF. orbit-loader fs_opens that path from
# the tarfs disk image and create_process()s the result. Build order:
#   orbit-loader/  → kmain include_bytes!s it
#   kmain          → bl include_bytes!s it
#   bl             → -kernel for QEMU
#   tools/build-disk.sh → packs user binaries (console, smoke=umode,
#                         hello-std, hello) into disk.img, served via
#                         virtio-blk and mounted as tarfs at /
note "building orbit-loader (release)"
( cd "$ROOT/orbit-loader" && time cargo build --release --bin orbit-loader >/dev/null )

note "building kmain (release via build.sh, --features smoke)"
( cd "$ROOT/kmain" && time ./build.sh --features smoke >/tmp/orbit-smoke-kmain-build.log 2>&1 ) \
  || die "kmain build failed (see /tmp/orbit-smoke-kmain-build.log)"

note "building bl (release)"
( cd "$ROOT/bl" && time cargo build --release --bin launch >/dev/null )

BL_BIN="$ROOT/bl/target/riscv64gc-unknown-none-elf/release/launch"
[ -x "$BL_BIN" ] || die "bl binary missing at $BL_BIN"

note "building disk.img from rootfs/ (umode → /bin/smoke, console, hello-std, hello)"
"$ROOT/tools/build-disk.sh" >/dev/null
[ -s "$ROOT/disk.img" ] || die "disk.img missing at $ROOT/disk.img"

# --- pre-flight: is port 65535 free? ---
# A stale nc from a prior failed run will squat on the port and make the
# new listener fail silently, after which the guest's SYN gets RST and
# "tcp connected!" never appears in the log.
if ss -ltn 2>/dev/null | grep -q ':65535 '; then
  die "port 65535 already in use — kill the existing listener first (ss -ltnp | grep :65535)"
fi

# --- host-side listener ---
# The feeder runs as nc's stdin. The initial sleep lets the guest finish
# its 5s sleep, create the netchannel, and complete the TCP handshake
# before we send anything. The gap between "hi!" and "exit" is so umode
# sees them as distinct TCP segments — recv_tcp looks for "exit" as a
# prefix, and a combined "hi!\nexit\n" packet would start with "hi!".
note "starting nc listener on :65535"
(
  sleep 10
  printf 'hi!\n'
  sleep 2
  printf 'exit\n'
  sleep 1
) | nc -l 65535 >"$NC_LOG" 2>&1 &
NC_PID=$!

# Give nc a moment to bind before we launch QEMU. A guest SYN that
# arrives before nc is listening gets RST by the host kernel.
sleep 1
kill -0 "$NC_PID" 2>/dev/null || die "nc failed to start (port 65535 in use?)"

trap 'kill "$NC_PID" 2>/dev/null || true' EXIT

# --- run qemu ---
# stdin is explicitly /dev/null so QEMU doesn't put the user's terminal
# into raw mode (via -serial mon:stdio) and then stall waiting on reads.
# Without this, when run from an interactive shell the serial output
# never reaches the log before timeout kills QEMU.
note "booting qemu (timeout ${QEMU_TIMEOUT}s)"
timeout "$QEMU_TIMEOUT" qemu-system-riscv64 \
  -d guest_errors -smp 4 -m 2G \
  -machine virt,aclint=on -cpu max,sstc=true \
  -nographic -bios none -serial mon:stdio \
  -netdev user,id=orbit0,net=192.168.76.0/24,dhcpstart=192.168.76.9 \
  -device e1000,netdev=orbit0 \
  -global virtio-mmio.force-legacy=off \
  -drive file="$ROOT/disk.img",format=raw,if=none,id=hd0,readonly=on,file.locking=off \
  -device virtio-blk-device,drive=hd0 \
  -kernel "$BL_BIN" \
  </dev/null >"$QEMU_LOG" 2>&1 || true

# Kill nc explicitly before waiting — if QEMU timed out before umode's
# close_handle reached the socket, nc never sees a clean FIN and would
# otherwise hang here indefinitely.
kill "$NC_PID" 2>/dev/null || true
wait "$NC_PID" 2>/dev/null || true

# --- verify guest serial log ---
[ -s "$QEMU_LOG" ] || die "QEMU produced no output (log empty: $QEMU_LOG). \
Is qemu-system-riscv64 on PATH? Did something kill QEMU before it could boot?"

note "checking QEMU serial log markers"
MARKERS=(
  # virtio-blk discovered on the bus (device_id=2 = block). Pure
  # transport-layer check; no driver attached yet (12a).
  'virtio_mmio@.* device_id=2'
  # virtio-blk synchronous read of LBA 0 — proves device + queue +
  # arena work end-to-end. First 2 bytes "2e2f" = "./", the first
  # entry in the ustar archive (the rootfs root directory).
  'virtio-blk: sync read ok lba=0 first8=2e2f'
  # tarfs eager-mount walked the whole archive without a parse error.
  'tarfs: mounted [1-9][0-9]* entries'
  # Path normalization (./README → /README) and the bin subdirectory
  # entry (path-with-subdir, plus directory typeflag) both land.
  'tarfs: .* path=/README'
  'tarfs: .* path=/bin'
  'tarfs: .* path=/bin/hello.txt'
  # §12d FS syscalls — open/read/stat/close against the mounted tarfs.
  'PASS: fs_stat /README size=217'
  'PASS: fs_stat /bin dir'
  'PASS: fs_open /bin/hello.txt fd='
  'PASS: fs_read /bin/hello.txt n=26 matches'
  'PASS: fs_read past EOF returns 0'
  'PASS: fs close /bin/hello.txt fd='
  'PASS: fs_open missing got Err\(errno=2\)'
  # fs_readdir — synthesized root, /bin sub-listing, EOD, ENOTDIR.
  'PASS: fs_readdir / opened fd='
  'PASS: fs_readdir / count=2 README\+bin with right d_type'
  'PASS: fs_readdir / EOD returns 0'
  'PASS: fs_readdir /bin contains hello\+hello.txt \(count=[0-9]+\)'
  'PASS: fs_readdir on regular file got Err\(errno=20\)'
  '=== fs smoke done ==='
  # §13e tarfs-init: orbit-loader (pid 1) reads /bin/smoke off the
  # disk and create_process()s it as pid 2. envp=inherited confirms
  # orbit-loader propagated its kernel-installed env to the child via
  # create_process_with_argv_envp (Phase 5/6 boot env delivery).
  'orbit-loader: spawned init /bin/smoke pid=2 bytes=[0-9]+ envp=inherited'
  # §13e boot envp end-to-end: orbit-loader sees the three kmain-
  # packed entries on first env::vars() access.
  'orbit-loader: boot env \(3 entries\):'
  '  PATH=/bin'
  '  HOME=/'
  '  TERM=dumb'
  # §13e env probe in umode (pid 2) — kmain pack → install_envp_blob →
  # orbit-loader inherit + repack → install_envp_blob → seeded BTreeMap.
  'PASS: env PATH=/bin'
  'PASS: env HOME=/'
  'PASS: env TERM=dumb'
  'PASS: env vars count=3'
  'PASS: env set_var/var round trip'
  'PASS: env remove_var clears entry'
  # §13a.1 — getpid/gettid land synchronously off the per-hart context.
  # Pid is whatever orbit-loader assigned us; just match the numeric.
  'PASS: getpid main got [0-9]+'
  'PASS: gettid main got [0-9]+ \(stable across calls\)'
  # §13a.2 wait_pid — happy path picks up hello's exit(42), error
  # paths cover EINVAL (self-wait) / ECHILD (missing or post-reap).
  'PASS: exec_smoke wait_pid pid=[0-9]+ got 42'
  'PASS: wait_pid self got Err\(errno=22\)'
  'PASS: wait_pid missing got Err\(errno=10\)'
  'PASS: wait_pid post-reap got Err\(errno=10\)'
  # §12e exec — read /bin/hello off the disk, hand to create_process,
  # child prints its own marker.
  'PASS: exec_smoke fs_stat /bin/hello size='
  'PASS: exec_smoke read [0-9]+ bytes from /bin/hello'
  'PASS: exec_smoke ELF magic present'
  'PASS: exec_smoke create_process_with_argv pid='
  # §13a.3 hello-side argv prints. argc=3 corresponds to the
  # ["/bin/hello", "world", "peace"] blob umode packs. With the
  # tarfs-init rework, pids are: 1=orbit-loader, 2=umode (smoke),
  # 3=hello (umode's exec_smoke child).
  'USER\[3\.[0-9]+\]: hello argc=3'
  'USER\[3\.[0-9]+\]: hello argv\[0\]=/bin/hello'
  'USER\[3\.[0-9]+\]: hello argv\[1\]=world'
  'USER\[3\.[0-9]+\]: hello argv\[2\]=peace'
  'USER\[3\.[0-9]+\]: hello from /bin/hello'
  '=== exec smoke done ==='
  # umode is pid 2 now (orbit-loader spawned it from /bin/smoke).
  'USER\[2\]: hello world!'
  'USER\[2\]: netchannel created!'
  'USER\[2\]: tcp connected!'
  'USER\[2\]: hi!'
  'USER\[2\]: exit'
  'USER\[2\]: close_handle ok!'
  # Syscall error-path assertions run from the umode test harness —
  # each validates a specific kernel return-code branch that the happy
  # path never touches. Errno codes match orbit-abi/src/errno.rs (Linux
  # numbering): EINVAL=22, EFAULT=14, EBADF=9.
  'PASS: sleep_ms at cap got Err\(errno=22\)'
  'PASS: sleep_ms above cap got Err\(errno=22\)'
  'PASS: serial_print null VA got Err\(errno=14\)'
  'PASS: serial_print too long got Err\(errno=22\)'
  'PASS: serial_print non-utf8 got Err\(errno=22\)'
  'PASS: console_write null VA got Err\(errno=14\)'
  'PASS: console_write too long got Err\(errno=22\)'
  'PASS: console_write non-utf8 got Ok\(4\)'
  'PASS: close_handle no registry got Err\(errno=9\)'
  'PASS: close_handle bogus fd got Err\(errno=9\)'
  'PASS: get_affinity initial cur=0x[0-9a-f]+ allowed=0x[0-9a-f]+'
  'PASS: set_affinity zero got Err\(errno=22\)'
  'PASS: set_affinity outside cap got Err\(errno=1\)'
  'PASS: set_affinity pinned to hart 0 \(got hart 0\)'
  'PASS: create_thread worker ran on hart 1'
  'PASS: TLS isolation'
  # §13a.5 futex round-trip: EAGAIN fast path, wake-after-park,
  # wake-on-empty-queue.
  'PASS: futex_wait value mismatch got Err\(errno=11\)'
  'PASS: futex_wake n=1 woke 1'
  'PASS: futex_wait worker resumed \(code=0\)'
  'PASS: futex_wake empty queue woke 0'
  'PASS: shootdown probe — worker faulted on post-revoke read'
  # Sentinel — printed by umode after the last error-path check returns.
  # Without this, a panic / early-exit between two PASS markers would only
  # show as a single missing marker; the sentinel pins "every test ran to
  # completion".
  '=== error path tests done ==='
)
for pat in "${MARKERS[@]}"; do
  if ! grep -qE "$pat" "$QEMU_LOG"; then
    die "missing marker in QEMU log: $pat  (see $QEMU_LOG)"
  fi
done

# --- verify host-side receive ---
note "checking nc received guest payload"
grep -q 'Hello World!' "$NC_LOG" \
  || die "nc did not receive 'Hello World!' from guest (see $NC_LOG)"

tail -n 1000 "$QEMU_LOG"
note "PASS"
